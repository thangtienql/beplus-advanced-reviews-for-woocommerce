{
	"compilerOptions": {
		"target": "es2017",
		"module": "esnext",
		"moduleResolution": "bundler",
		"jsx": "react-jsx",
		"noEmit": true,
		"resolveJsonModule": true,
		"allowSyntheticDefaultImports": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"strict": false
	},
	"include": [
		"blocks/**/*.ts",
		"blocks/**/*.tsx",
		"admin/js/**/*.ts",
		"types/**/*.d.ts"
	]
}
